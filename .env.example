# ── Telegram Bot (optional — Gemini Live is the primary interface) ──────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username_here

# ── Google AI / Gemini Live API ─────────────────────────────────────────────
# Used for: Gemini Live voice sessions, Gemini 2.5 Pro/Flash text generation
# Get at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Cloud (Vertex AI, Firestore, GCS, Cloud Run) ─────────────────────
GOOGLE_CLOUD_PROJECT=your_gcp_project_id_here
GOOGLE_CLOUD_REGION=us-central1
GCS_BUCKET=your_gcp_project_id-echo-media

# ── Deployment ───────────────────────────────────────────────────────────────
# Set to your Cloud Run URL after deploying
CLOUD_RUN_URL=https://your-cloud-run-url.run.app
PORT=8080
